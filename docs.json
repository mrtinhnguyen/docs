  },
  "navbar": {
    "links": [
      {
        "label": "Cổng thông tin Sở",
        "href": "https://sodantoctongiao.hanoi.gov.vn/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "website": "https://sodantoctongiao.hanoi.gov.vn/",
      "facebook": "https://facebook.com/Dttghanoi"
    }
