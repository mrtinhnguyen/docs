{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Sổ Tay Điện Tử - Tôn giáo, Tĩn ngưỡng và Chính sách Dân tộc",
  "colors": {
    "primary": "#0d066d",
    "light": "#d52b0f",
    "dark": "#ffffff"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Sổ tay Tôn giáo – Dân tộc",
        "icon": "notebook",
        "pages": [
          "loi-mo-dau",
          {
            "group": "Getting started",
            "pages": []
          },
          {
            "group": "Customization",
            "pages": []
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "Biểu mẫu Tôn giáo – Dân tộc",
        "icon": "book-font",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/sodantoctongiao-logo.png",
    "dark": "/images/sodantoctongiao-logo.png",
    "href": "https://sodantoctongiao.hanoi.gov.vn/"
  },
  "navbar": {
    "links": [
      {
        "label": "Cổng thông tin Sở",
        "href": "https://sodantoctongiao.hanoi.gov.vn/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "website": "https://sodantoctongiao.hanoi.gov.vn/",
      "facebook": "https://facebook.com/Dttghanoi"
    }
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "timestamp": true
  },
  "appearance": {
    "strict": true,
    "default": "light"
  },
  "background": {
    "decoration": "windows"
  },
  "fonts": {
    "family": "Roboto"
  }
}
