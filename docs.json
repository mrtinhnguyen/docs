              "co-so-tho-tu",
              "yeu-to-nuoc-ngoai"
            ]
          },
          {
            "group": "4. Chính sách Dân tộc",
            "pages": [
              "dinh-muc-ho-tro",
              "quy-trinh-thuc-hien",
              "chinh-sach-khac",
              "bieu-mau-ap-dung"
            ]
