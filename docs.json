          {
            "group": "5. Quản lý & Tình huống",
            "pages": [
              "quan-ly-nha-nuoc",
              "cau-hoi-tinh-huong"
            ]
          },
          {
            "group": "6. Biểu mẫu & Quy trình",
            "pages": [
              "danh-muc-bieu-mau",
              "quy-trinh-nop-ho-so",
              "quy-trinh-chinh-sach-dan-toc"
            ]
          }
        ]
      },
      {
        "tab": "Biểu mẫu Tôn giáo – Dân tộc",
        "icon": "book-font",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
